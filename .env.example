IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your-imap-user
IMAP_PASSWORD=your-imap-password
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_MS=30000
# Max messages to process per poll (avoids burst; rest next cycle). 0 = no limit.
IMAP_MAX_MESSAGES_PER_POLL=50

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
REPLY_FROM="Auto Reply <no-reply@example.com>"
# Never auto-reply to these (bounce/system). Comma-separated substrings, e.g. mailer-daemon@,postmaster@
# REPLY_SKIP_ADDRESSES=mailer-daemon@,postmaster@

# Use redis://redis:6379/0 with Docker Compose; use redis://localhost:6379/0 when running locally
REDIS_URL=redis://redis:6379/0

QUEUE_NAME=email-replies
QUEUE_CONCURRENCY=5
QUEUE_RATE_LIMIT_MAX=30
QUEUE_RATE_LIMIT_DURATION_MS=60000
# Stagger each job in a batch by this many ms (e.g. 2000 = 2s between sends). 0 = no delay.
QUEUE_JOB_DELAY_MS=0

PER_SENDER_MAX_REPLIES=10
PER_SENDER_WINDOW_MS=3600000

